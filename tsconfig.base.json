{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "skipLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "@codemap/shared/*": [
        "packages/shared/src/*"
      ],
      "@codemap/ui/*": [
        "packages/ui/src/*"
      ]
    }
  }
}
